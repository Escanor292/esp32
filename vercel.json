{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "dashboard/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "build"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/v1/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/sepay-webhook",
      "dest": "server.js"
    },
    {
      "src": "/static/(.*)",
      "dest": "dashboard/build/static/$1"
    },
    {
      "src": "/(.*\\.(js|css|json|ico|png|jpg|svg|txt))",
      "dest": "dashboard/build/$1"
    },
    {
      "src": "/(.*)",
      "dest": "dashboard/build/index.html"
    }
  ]
}
