# Environment Variables for Payment Notification System

# ============ MQTT Configuration ============
# MQTT broker URL for device communication
# Default: mqtt://broker.hivemq.com:1883
MQTT_BROKER_URL=mqtt://broker.hivemq.com:1883

# Store/Device identifier used in MQTT topics
# Default: store_001
STORE_ID=store_001

# ============ Database Configuration ============
# PostgreSQL database connection settings
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=
DB_NAME=payment_system
DB_PORT=5432

# ============ Redis Configuration ============
# Redis URL for caching and session management
# Default: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# ============ Payment Gateway Configuration ============
# SePay API key for payment webhook integration
SEPAY_API_KEY=your_sepay_api_key

# ============ Server Configuration ============
# Server port (only used in local development, not on Vercel)
# Default: 8081
PORT=8081

# Node environment (development, production)
NODE_ENV=development

# ============ Vercel Configuration ============
# Automatically set by Vercel platform (do not set manually)
# VERCEL=1
